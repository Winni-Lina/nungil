# ============================================================
#  눈길(Nungil) 서버 설정 템플릿
# ------------------------------------------------------------
#  이 파일을 복사해 같은 폴더에 application.properties 로 저장한 뒤,
#  아래 값(YOUR_...)을 본인 환경에 맞게 채우세요.
#
#    cp application.properties.example application.properties
#
#  ⚠️ application.properties 에는 실제 비밀번호·키가 들어가므로
#     절대 Git에 커밋하지 마세요(.gitignore에 등록되어 있습니다).
# ============================================================

# ── 데이터베이스 (Oracle) ───────────────────────────────────
db.driver=oracle.jdbc.OracleDriver
db.url=jdbc:oracle:thin:@localhost:1521/orcl
db.username=nungil
db.password=YOUR_DB_PASSWORD

# ── Google Vertex AI (Gemini) + Cloud STT 공용 서비스 계정 ──
#  GCP 서비스 계정 JSON 키를 아래 경로에 저장:
#    server/src/main/resources/serviceAccountKey.json
google.service-account-key=classpath:serviceAccountKey.json
google.vertex.project-id=YOUR_GCP_PROJECT_ID
google.vertex.location=us-central1

# ── (선택) 일부 환경에서 사용하는 Gemini API 키 ────────────
#  Vertex AI(위 서비스 계정) 방식이 기본이며, 아래는 필요 시에만 사용.
# google.ai.api-key=YOUR_GEMINI_API_KEY

# ------------------------------------------------------------
#  Firebase(FCM) 키는 프로퍼티가 아니라 파일로 배치합니다:
#    server/src/main/resources/firebase/serviceAccountKey.json
#  또는 환경변수 FIREBASE_SERVICE_ACCOUNT_JSON 에 JSON 전체를 넣어도 됩니다.
# ------------------------------------------------------------
