<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nungil.domain.question.QuestionMapper">

    <resultMap id="QuestionResultMap" type="com.nungil.domain.question.QuestionVO">
        <id     property="questionId" column="question_id"/>
        <result property="id"         column="id"/>
        <result property="idx"        column="idx"/>
        <result property="content"    column="content"/>
        <result property="answer"     column="answer"/>
        <result property="status"     column="status"/>
        <result property="createdAt"  column="created_at"/>
        <result property="successAt"  column="success_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.nungil.domain.question.QuestionVO">
        <selectKey keyProperty="questionId" resultType="long" order="AFTER">
            SELECT MAX(question_id) FROM QUESTION WHERE id = #{id} AND idx = #{idx}
        </selectKey>
        INSERT INTO QUESTION (id, idx, content, answer, status)
        VALUES (#{id}, #{idx}, #{content}, #{answer}, 'pending')
    </insert>

    <select id="findById" resultMap="QuestionResultMap">
        SELECT * FROM QUESTION WHERE question_id = #{questionId}
    </select>

    <update id="updateComplete">
        UPDATE QUESTION SET status = 'completed', success_at = CURRENT_TIMESTAMP
        WHERE question_id = #{questionId}
    </update>

    <!-- NT-004: 최근 1시간 내 pending 질문 2개 이상인 사용자 -->
    <select id="findRecentRepeatUsers" resultType="java.util.HashMap">
        SELECT id, idx, COUNT(*) AS cnt
        FROM QUESTION
        WHERE status = 'pending'
          AND created_at > SYSDATE - 1/24
        GROUP BY id, idx
        HAVING COUNT(*) >= 2
    </select>

</mapper>
